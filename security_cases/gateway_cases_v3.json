    "id": "v3_path_traversal_dotdot_env",
    "category": "attack",
    "description": "路径穿越读取.env文件，应确认或拒绝。",
    "request": {
      "user": "user",
      "tool": "file.read",
      "params": {
        "path": "../../.env"
      }
    },
    "expected_decision_in": ["confirm", "deny"]
  },
