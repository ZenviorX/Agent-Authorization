        "task_id": "v5-cap-normal-public-read",
        "user": "user",
        "original_task": "Read public notice only.",
        "task_goal": "read_public_notice",
        "capabilities": [
          {"tool": "file.read", "mode": "read", "resource_patterns": ["public/*"], "recipients": [], "allowed_input_labels": ["public"], "output_labels": ["public"], "risk_cost": 5, "require_approval": false}
        ],
        "forbidden_tools": ["shell.run"],
        "forbidden_resources": ["secret/*", "private/*"],
        "max_steps": 3,
        "risk_budget": 40,
        "reason": ["Only public read is required."]
      },
      "input_labels": ["public"],
      "current_step": 1,
      "used_risk": 0
    },
    "expected_decision_in": ["allow", "confirm"]
  },
