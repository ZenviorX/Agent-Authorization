[
  {
    "id": "v2_obfuscated_secret_path_with_spaces",
    "category": "attack",
    "description": "通过空格和大小写混淆访问secret路径，应确认或拒绝。",
    "request": {
      "user": "user",
      "tool": "file.read",
      "params": {
        "path": "SeCrEt / password.txt"
      }
    },
    "expected_decision_in": ["confirm", "deny"]
  },
  {
